{
  "private": true,
  "scripts": {
    "lint:css": "stylelint '**/*.scss' --fix; exit 0",
    "build:css": "sass Private/Frontend/Scss/main.scss:public/styles/main.css",
    "prefix:css": "postcss public/styles/main.css --use=autoprefixer --output=public/styles/main.css",
    "minify:css": "cleancss -o public/styles/main.min.css public/styles/main.css",
    "watch:css": "onchange -i 'Private/Frontend/**/*.scss' -- sh -c 'npm run lint:css && npm run build:css && npm run prefix:css'",
    "export:css": "NODE_ENV=production npm run build:css && npm run && npm run prefix:css && npm run minify:css",
    "watch:js": "node_modules/.bin/rollup -c --watch",
    "export:js": "NODE_ENV=production node_modules/.bin/rollup -c",
    "build:html": "pug Private/Frontend/Pug/*.pug -o Private/Frontend/Html/ -P",
    "watch:html": "onchange -i 'Private/Frontend/**/*.pug' -- sh -c 'npm run build:html && npm run export:html && npm run export:html-comp && npm run export:html-globals'",
    "export:html": "pug Private/Frontend/Pug/*.pug -o Private/Frontend/Html/ -P",
    "export:html-comp": "pug Private/Frontend/Pug/components/*.pug -o Private/Frontend/Html/components/ -P",
    "export:html-globals": "pug Private/Frontend/Pug/globals/*.pug -o Private/Frontend/Html/globals/ -P",
    "clean-dev": "rimraf Private/Frontend/Html/* public/Scripts/Dev/* public/Scripts/Legacy/Dev/*",
    "clean": "rimraf public/Scripts/*.js public/Scripts/Legacy/*.js public/Scripts/Dev/* public/Scripts/Legacy/Dev/*",
    "build": "npm run clean && npm run export:css && npm run build:html && npm run export:js",
    "browsersync": "browser-sync start --server --files 'public/styles/*.css, Private/Frontend/Html/*.html, public/Scripts/Dev/*.js' --startPath 'public/'",
    "dev": "npm run clean-dev && npm-run-all --parallel watch:css watch:js watch:html browsersync",
    "copy-needed": "copyfiles -f node_modules/systemjs/dist/s.min.js node_modules/promise-polyfill/dist/polyfill.min.js public/Scripts/Helpers/",
    "postinstall": "patch-package && npm run copy-needed"
  },
  "dependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "a11y-dialog": "^8.0.0",
    "core-js": "^3.20.2",
    "delicious-hamburgers": "^1.2.0",
    "enquire-js": "^0.2.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "promise-polyfill": "^8.2.1",
    "sass-mq": "^6.0.0-beta.1",
    "scss-resets": "^0.5.2",
    "swiper": "^8.4.5",
    "systemjs": "^6.11.0",
    "unitconversion": "^2.1.13"
  },
  "devDependencies": {
    "@babel/cli": "^7.16.8",
    "@babel/core": "^7.11.6",
    "@babel/plugin-transform-runtime": "^7.16.8",
    "@babel/preset-env": "^7.16.8",
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-eslint": "^8.0.1",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "@rollup/plugin-strip": "^2.1.0",
    "autoprefixer": "^10.4.2",
    "browser-sync": "^2.26.7",
    "clean-css-cli": "^5.3.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.6.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "patch-package": "^6.4.7",
    "postcss": "^8.4.5",
    "postcss-cli": "^9.1.0",
    "pug": "^3.0.2",
    "pug-cli": "^1.0.0-alpha6",
    "purgecss": "^5.0.0",
    "regenerator-runtime": "^0.13.9",
    "rimraf": "^3.0.2",
    "rollup": "^2.63.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-terser": "^7.0.2",
    "sass": "^1.43.5",
    "stylelint": "^14.1.0",
    "stylelint-config-standard": "^24.0.0",
    "stylelint-config-standard-scss": "^3.0.0",
    "stylelint-scss": "^4.0.0"
  }
}
