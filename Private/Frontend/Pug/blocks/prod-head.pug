link(rel='stylesheet', href="Styles/main.min.css")

//- Please comment out/in one of the following script loading blocks, depending on required build targets set in .browserlistrc
//- we support IE11 only on special request

//- only modern / Start
script(type="module", src="Scripts/main.js")
//- only modern / End

//- modern and IE11 / Start
//- script.
    import("../../../Public/Scripts/main.js");
    window.supportsDynamicImport = true;
//- script.
    if (typeof Promise === 'undefined')
        document.write('<script src="../../../Public/Scripts/Helpers/polyfill.min.js"><\/script>');
    
//- script.
    if (!window.supportsDynamicImport) {
        const systemJsLoaderTag = document.createElement('script');
        systemJsLoaderTag.src = '../../../Public/Scripts/Helpers/s.min.js';
        systemJsLoaderTag.addEventListener('load', function () {
            System.import('../../../Public/Scripts/Legacy/main.js');
        });
        document.head.appendChild(systemJsLoaderTag);
    }
//- modern and IE11 / End