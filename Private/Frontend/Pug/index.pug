extends ./layout/layout.pug

block config
    - var pagetitle = "Willkommen";
    - var activePage = "startseite";

block content
    .c-landing 
        .c-landing-body 
            h1.c-landing_title.u-font.-thymesion 
                span Tami <span class="u-font -core"> & &nbsp;</span>
                span Lucas
            h2.h-h3.u-font.-quinoa wollen heiraten

            p Du bist eingeladen 
            .c-landing_form 
                input(type="text" placeholder="Username")#username
                input(type="password" placeholder="Passwort")#password
                button.g-btn(onclick="login()") Login 
                p#error(style="color:red;")

    script.
        async function login() {
            const user = document.getElementById('username').value;
            const pass = document.getElementById('password').value;
            const headers = new Headers();
            headers.append('Authorization', 'Basic ' + btoa(user + ':' + pass));

            try {
                const res = await fetch('/api/auth', { headers });
                if(res.status === 200) {
                window.location.href = '/protected'; // or show content inline
                } else if(res.status === 401) {
                document.getElementById('error').textContent = 'Falsche Logindaten';
                } else {
                document.getElementById('error').textContent = 'Server error';
                }
            } catch(e) {
                document.getElementById('error').textContent = 'Network error';
            }
        }